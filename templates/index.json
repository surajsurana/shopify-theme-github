    "custom_liquid_UW8UhA": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "custom_liquid": "<div class=\"highlight-section\">\n  <div class=\"icon-scroll\">\n    <div class=\"icon-item\">\n      <img src=\"{{ 'fabric.png' | asset_url }}\" alt=\"Pure & Premium Fabrics\">\n      <h3>Pure & Premium Fabrics</h3>\n      <p>At the heart of every outfit lies the fabric. We use only the finest Natural Fibre Fabrics, ensuring they are soothing to the body, breathable, and luxurious to wear. Experience the comfort and elegance of premium quality in every stitch.</p>\n    </div>\n    <div class=\"icon-item\">\n      <img src=\"{{ 'embroidery.png' | asset_url }}\" alt=\"Handcrafted Embroidery\">\n      <h3>Handcrafted Embroidery</h3>\n      <p>We cherish the artistry of hand embroidery, where each detail is carefully crafted by skilled karigars. Our commitment to tradition means no machine embroidery—only the timeless touch of human hands, ensuring a perfect, personalized fit for every garment.</p>\n    </div>\n    <div class=\"icon-item\">\n      <img src=\"{{ 'dhl.png' | asset_url }}\" alt=\"Express Shipping by DHL\">\n      <h3>Express Shipping by DHL</h3>\n      <p>Timeliness is key, and we know how crucial it is for you to receive your outfits without delay. That's why we partner exclusively with DHL Express, guaranteeing your purchase arrives swiftly and safely, no matter where you are.</p>\n    </div>\n  </div>\n</div>\n\n<style>\n  .highlight-section {\n    display: flex;\n    justify-content: space-between;\n    padding: 20px 0;\n  }\n\n  .icon-scroll {\n    display: flex;\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none; /* Firefox */\n    -ms-overflow-style: none;  /* Internet Explorer 10+ */\n  }\n\n  .icon-scroll::-webkit-scrollbar {\n    display: none; /* Safari and Chrome */\n  }\n\n  .icon-item {\n    flex: 0 0 30%;\n    text-align: center;\n    padding: 10px;\n  }\n\n  .icon-item img {\n    max-width: 80px;\n    margin-bottom: 10px;\n  }\n\n  .icon-item h3 {\n    font-size: 18px;\n    margin-bottom: 5px;\n  }\n\n  .icon-item p {\n    font-size: 14px;\n  }\n\n  @media only screen and (max-width: 767px) {\n    .icon-item {\n      flex: 0 0 90%;\n    }\n  }\n</style>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
