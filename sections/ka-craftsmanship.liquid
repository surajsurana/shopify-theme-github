{{ 'ka-craftsmanship.css' | asset_url | stylesheet_tag }}

<section class="ka-craftsmanship">

  <div class="ka-craftsmanship__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ka-craftsmanship__eyebrow scroll-trigger animate--fade-in">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ka-craftsmanship__heading scroll-trigger animate--fade-in">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="ka-craftsmanship__intro scroll-trigger animate--fade-in">{{ section.settings.intro }}</p>
    {%- endif -%}
  </div>

  <div class="ka-craft-grid">

    {%- assign steps = '1,2,3,4' | split: ',' -%}
    {%- assign numerals = '01,02,03,04' | split: ',' -%}
    {%- for i in steps -%}
      {%- assign title_key = 'step_' | append: i | append: '_title' -%}
      {%- assign desc_key  = 'step_' | append: i | append: '_desc' -%}
      {%- assign img_key   = 'step_' | append: i | append: '_image' -%}
      {%- assign num       = numerals[forloop.index0] -%}
      <div class="ka-craft-item scroll-trigger animate--fade-in">
        <div class="ka-craft-item__image">
          {%- if section.settings[img_key] != blank -%}
            <img
              src="{{ section.settings[img_key] | image_url: width: 600 }}"
              alt="{{ section.settings[title_key] | escape }}"
              loading="lazy"
              width="600"
              height="800"
            >
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <span class="ka-craft-item__number">{{ num }}</span>
        {%- if section.settings[title_key] != blank -%}
          <p class="ka-craft-item__label">{{ section.settings[title_key] }}</p>
        {%- endif -%}
        {%- if section.settings[desc_key] != blank -%}
          <p class="ka-craft-item__desc">{{ section.settings[desc_key] }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </div>

  {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
    <div class="ka-craftsmanship__cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="ka-craftsmanship__cta scroll-trigger animate--fade-in">
        {{ section.settings.cta_label }}
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "KA Craftsmanship",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Atelier"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Four centuries of craft in every garment"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Body intro",
      "default": "Our studio in Mumbai brings together master craftspeople from across India. Each piece is constructed by hand, through processes refined over generations."
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "image_picker",
      "id": "step_1_image",
      "label": "Step 1 image"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Step 1 title",
      "default": "Hand Embroidery"
    },
    {
      "type": "textarea",
      "id": "step_1_desc",
      "label": "Step 1 description",
      "default": "Each piece is embroidered by hand — zari, zardozi, and thread-work applied stitch by stitch under natural light."
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "image_picker",
      "id": "step_2_image",
      "label": "Step 2 image"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Step 2 title",
      "default": "Fabric Selection"
    },
    {
      "type": "textarea",
      "id": "step_2_desc",
      "label": "Step 2 description",
      "default": "We source silks, organzas, and velvets from Banaras, Kanchipuram and Surat — selecting only what passes the hand-feel test."
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "image_picker",
      "id": "step_3_image",
      "label": "Step 3 image"
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "Step 3 title",
      "default": "Draping"
    },
    {
      "type": "textarea",
      "id": "step_3_desc",
      "label": "Step 3 description",
      "default": "Every silhouette begins on the body, not on paper. Our drapers work directly with the cloth until the fall is exactly right."
    },
    {
      "type": "header",
      "content": "Step 4"
    },
    {
      "type": "image_picker",
      "id": "step_4_image",
      "label": "Step 4 image"
    },
    {
      "type": "text",
      "id": "step_4_title",
      "label": "Step 4 title",
      "default": "Final Fitting"
    },
    {
      "type": "textarea",
      "id": "step_4_desc",
      "label": "Step 4 description",
      "default": "We insist on at least two in-person fittings. The garment is adjusted to the bride, not the other way around."
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "KA Craftsmanship"
    }
  ]
}
{% endschema %}
