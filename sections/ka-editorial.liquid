{{ 'ka-editorial.css' | asset_url | stylesheet_tag }}

{%- assign image_side = section.settings.image_side | default: 'left' -%}

<section class="ka-editorial">
  <div class="ka-editorial__inner{% if image_side == 'right' %} ka-editorial__inner--image-right{% endif %}">

    <div class="ka-editorial__image ka-reveal">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1400 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
          width="1400"
          height="1867"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="ka-editorial__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ka-editorial__eyebrow ka-reveal">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ka-editorial__title ka-reveal">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="ka-editorial__body ka-reveal">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="ka-editorial__link ka-reveal">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "KA Editorial Feature",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Client Diaries"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The bride before the moment — in her own words"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Our Client Diaries series captures the relationship between a woman and her wedding wardrobe — not as a transaction, but as a rite. Here, real brides speak about the garments that held them on the most important day of their lives."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Read the Stories"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "KA Editorial Feature"
    }
  ]
}
{% endschema %}
