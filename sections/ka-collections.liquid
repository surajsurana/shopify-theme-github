{{ 'ka-collections.css' | asset_url | stylesheet_tag }}

<section class="ka-collections">

  <div class="ka-collections__header scroll-trigger animate--fade-in">
    <div class="ka-collections__header-left">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ka-collections__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ka-collections__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_url != blank -%}
      <a href="{{ section.settings.view_all_url }}" class="ka-collections__view-all">
        View all
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    {%- endif -%}
  </div>

  <div class="ka-collections__grid">

    {%- comment -%} Card 1 — Featured (spans 2 rows) {%- endcomment -%}
    <a
      href="{{ section.settings.card_1_url | default: '#' }}"
      class="ka-collection-card ka-collection-card--featured scroll-trigger animate--fade-in"
    >
      <div class="ka-collection-card__image">
        {%- if section.settings.card_1_image != blank -%}
          <img
            src="{{ section.settings.card_1_image | image_url: width: 1200 }}"
            alt="{{ section.settings.card_1_name | escape }}"
            loading="lazy"
            width="1200"
            height="1600"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="ka-collection-card__overlay"></div>
        <div class="ka-collection-card__info">
          <p class="ka-collection-card__name">{{ section.settings.card_1_name | default: 'The Bloom Soirée' }}</p>
          {%- if section.settings.card_1_count != blank -%}
            <p class="ka-collection-card__count">{{ section.settings.card_1_count }}</p>
          {%- endif -%}
          <span class="ka-collection-card__cta">
            Explore
            <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </div>
    </a>

    {%- comment -%} Cards 2–5 (smaller) {%- endcomment -%}
    {%- assign small_cards = '2,3,4,5' | split: ',' -%}
    {%- for i in small_cards -%}
      {%- assign name_key  = 'card_' | append: i | append: '_name' -%}
      {%- assign count_key = 'card_' | append: i | append: '_count' -%}
      {%- assign img_key   = 'card_' | append: i | append: '_image' -%}
      {%- assign url_key   = 'card_' | append: i | append: '_url' -%}
      <a
        href="{{ section.settings[url_key] | default: '#' }}"
        class="ka-collection-card scroll-trigger animate--fade-in"
      >
        <div class="ka-collection-card__image">
          {%- if section.settings[img_key] != blank -%}
            <img
              src="{{ section.settings[img_key] | image_url: width: 900 }}"
              alt="{{ section.settings[name_key] | escape }}"
              loading="lazy"
              width="900"
              height="1200"
            >
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="ka-collection-card__overlay"></div>
          <div class="ka-collection-card__info">
            <p class="ka-collection-card__name">{{ section.settings[name_key] }}</p>
            {%- if section.settings[count_key] != blank -%}
              <p class="ka-collection-card__count">{{ section.settings[count_key] }}</p>
            {%- endif -%}
            <span class="ka-collection-card__cta">
              Explore
              <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </div>
      </a>
    {%- endfor -%}

  </div>

</section>

