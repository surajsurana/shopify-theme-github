{{ 'ka-newsletter.css' | asset_url | stylesheet_tag }}

<section class="ka-newsletter">
  <div class="ka-newsletter__inner">

    {%- if section.settings.eyebrow != blank -%}
      <p class="ka-newsletter__eyebrow ka-reveal">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="ka-newsletter__title ka-reveal">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="ka-newsletter__body ka-reveal">{{ section.settings.body }}</p>
    {%- endif -%}

    <form
      class="ka-newsletter__form ka-reveal"
      action="/contact#contact_form"
      method="post"
      id="ka-newsletter-form"
    >
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        class="ka-newsletter__input"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
        aria-label="{{ section.settings.placeholder | default: 'Your email address' }}"
        required
      >
      <button type="submit" class="ka-newsletter__submit">
        {{ section.settings.button_label | default: 'Subscribe' }}
      </button>
    </form>

    {%- if section.settings.privacy_note != blank -%}
      <p class="ka-newsletter__privacy ka-reveal">{{ section.settings.privacy_note }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "KA Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay Close"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Letters from the atelier"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "New collections, behind-the-scenes from the studio, and invitations to private events — for those who follow closely."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "Curated, infrequent. We respect your inbox."
    }
  ],
  "presets": [
    {
      "name": "KA Newsletter"
    }
  ]
}
{% endschema %}
